# 数据库配置
# MY_APP_DATABASE_URL=mysql+asyncmy://mysql:Mysql_80@localhost:3306/star?charset=utf8mb4
MY_APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/star

# 本地存储配置
MY_APP_UPLOAD_DIR=./uploads/avatars  # 头像存储根目录
MY_APP_MAX_AVATAR_SIZE=5242880       # 最大文件大小：5MB（字节）
MY_APP_BASE_URL=http://0.0.0.0:4234  # 服务基础URL，用于拼接头像访问URL

MY_APP_BASE_HOST="0.0.0.0"
MY_APP_BASE_PORT='4234'
MY_APP_DEBUG_STATUS='True'

MY_APP_ACCESS_TOKEN_EXPIRE_MINUTES=15
MY_APP_ACCESS_TOKEN_EXPIRE_DAYS=7
MY_APP_ALGORITHM='RS256'

MY_APP_RATE_LIMIT = "5/second" # 频率限制配置（每秒最多 5 次请求）
